{
  "servers": {
    "context-mode": {
      "command": "context-mode"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "/usr/bin/chromium",
        "--ignore-default-chrome-arg=--disable-extensions",
        "--chromeArg=--disable-extensions-except=/home/scetrov/source/eve-vault-chrome",
        "--chromeArg=--load-extension=/home/scetrov/source/eve-vault-chrome"
      ]
    }
  }
}