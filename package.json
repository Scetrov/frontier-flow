{
  "name": "frontier-flow",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scetrov/frontier-flow.git"
  },
  "bugs": {
    "url": "https://github.com/Scetrov/frontier-flow/issues"
  },
  "scripts": {
    "dev": "vite",
    "debug:remote-deploy-grade-mcve": "bun run ./scripts/debug-remote-deploy-grade-mcve.ts",
    "build": "tsc -b && vite build",
    "build:with-world-contracts": "bun run fetch:world-contracts && bun run build",
    "debug:local-publish-mcve": "bun run ./scripts/debug-local-publish-mcve.ts",
    "fetch:world-contracts": "bun run ./scripts/fetch-world-contracts.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "bunx standard-version",
    "release:first": "bunx standard-version --first-release",
    "release:major": "bunx standard-version --release-as major",
    "release:minor": "bunx standard-version --release-as minor",
    "release:patch": "bunx standard-version --release-as patch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:real-wasm": "bun run ./scripts/real-wasm-integration.ts",
    "typecheck": "tsc -b",
    "audit": "bunx npm-audit --audit-level=high",
    "verify": "bun run lint && bun run typecheck && bun run test:run",
    "verify:full": "bun run verify && bun run build"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@mysten/dapp-kit": "1.0.4",
    "@mysten/sui": "2.9.1",
    "@tanstack/react-query": "^5.90.21",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.10.0",
    "@zktx.io/sui-move-builder": "0.2.8",
    "dagre": "^0.8.5",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "rolldown-vite": "7.3.1",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
