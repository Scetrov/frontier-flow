# Frontier Flow — Environment Variables
# Copy this file to .env for local development: cp .env.example .env
# See docs/DEPLOYMENT.md §3.2 for details.

# Base URL path — only override for subpath deployments (e.g. GitHub Pages)
# VITE_BASE_PATH=/frontier-flow/

# GitHub OAuth App client ID (future — for increased API rate limits)
# VITE_GITHUB_CLIENT_ID=your_dev_client_id
